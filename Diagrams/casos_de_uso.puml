@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Usuario Android" as User

rectangle "Sistema Inmobiliaria TFG" {
  usecase "Autenticación (Login/Registro)" as UC1
  usecase "Publicar Inmueble (con Fotos)" as UC2
  usecase "Buscar con Filtros Avanzados" as UC3
  usecase "Chat en Tiempo Real" as UC4
  usecase "Gestionar Favoritos" as UC5
  usecase "Eliminar mis Publicaciones" as UC6
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
@enduml
